{
  "name": "citadel",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/bump-build.js && vite build && node scripts/write-version.js",
    "preview": "vite preview",
    "test": "vitest run && vitest run --config vitest.api.config.js",
    "test:unit": "vitest run",
    "test:api": "vitest run --config vitest.api.config.js",
    "test:e2e": "npx playwright test",
    "test:all": "npm run test:unit && npm run test:api && npm run test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "axios": "^1.13.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^5.1.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "vite": "^7.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}
