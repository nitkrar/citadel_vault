# ===========================================================================
# Citadel Vault — Environment Configuration
# ===========================================================================
# Copy to .env and update values. NEVER commit .env to version control.
# Lines with "# CHANGE THIS" must be set before running.
# ===========================================================================

# ─── Application ──────────────────────────────────────────
APP_ENV=development                         # development = verbose errors; production = errors hidden + fail-closed
APP_URL=http://localhost:8081               # Base URL for email links and invites
ALLOWED_ORIGINS=*                           # CORS (* only in dev; set to domain in prod)
BASE_CURRENCY=GBP                           # Default currency for portfolio aggregation
SYNC_POLL_INTERVAL=900                      # Cross-device sync check interval in seconds (default: 15 min)

# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=citadel_vault_db
DB_USER=citadel_db_admin
DB_PASS=your-db-password                    # CHANGE THIS

# ─── Secrets (required — app refuses to start without these in prod) ──
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-me-run-openssl-rand-hex-64        # CHANGE THIS. Signs JWT auth tokens.
JWT_EXPIRY=28800                            # Token lifetime in seconds (default: 8 hours)

# Generate with: openssl rand -hex 32
AUDIT_HMAC_SECRET=replace-me-run-openssl-rand-hex-32 # CHANGE THIS. HMAC key for hashing IPs in audit log.

# Generate with: openssl rand -hex 32
SHARING_TOKEN_SECRET=replace-me-run-openssl-rand-hex-32 # CHANGE THIS. Signs recipient tokens for sharing flow.

# ─── WebAuthn (Passkey Login) ─────────────────────────────
# WARNING: Changing RP_ID or ORIGIN after passkey registration
# permanently invalidates those passkeys. Set once, don't change.
WEBAUTHN_RP_ID=localhost                    # Domain only, no protocol
WEBAUTHN_RP_NAME=Citadel                    # Display name in passkey prompts
WEBAUTHN_ORIGIN=http://localhost:8081       # Full origin with protocol

# ─── Security: Vault Key Policy ──────────────────────────
VAULT_KEY_MIN_LENGTH=8                      # Minimum characters for new vault keys
VAULT_KEY_MODE=alphanumeric                 # numeric | alphanumeric | any
BCRYPT_COST=12                              # bcrypt cost factor for password hashing

# ─── Security: Password Policy ───────────────────────────
PASSWORD_HISTORY_COUNT=1                    # Block reuse of last N passwords (0 = disabled)

# ─── Security: Account Lockout (progressive) ─────────────
LOCKOUT_TIER1_ATTEMPTS=3                    # Failures before tier 1 cooldown
LOCKOUT_TIER1_DURATION=900                  # Tier 1 cooldown seconds (15 min)
LOCKOUT_TIER2_ATTEMPTS=6                    # Failures before tier 2 cooldown
LOCKOUT_TIER2_DURATION=3600                 # Tier 2 cooldown seconds (1 hour)
LOCKOUT_TIER3_ATTEMPTS=9                    # Failures before forced credential change

# ─── Security: Rate Limiting (per IP) ────────────────────
RATE_LIMIT_LOGIN_IP=20
RATE_LIMIT_LOGIN_IP_WINDOW=900              # 15 min
RATE_LIMIT_REGISTER=5
RATE_LIMIT_REGISTER_WINDOW=3600             # 1 hour
RATE_LIMIT_FORGOT_PW=5
RATE_LIMIT_FORGOT_PW_WINDOW=3600
RATE_LIMIT_INVITE_REQ=3
RATE_LIMIT_INVITE_REQ_WINDOW=3600

# ─── Registration ─────────────────────────────────────────
SELF_REGISTRATION=false                     # true = anyone can register; false = invite-only
REQUIRE_EMAIL_VERIFICATION=false            # true = verify email before access

# ─── SMTP Email (optional) ───────────────────────────────
SMTP_ENABLED=false                          # Master switch
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-login
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@yourdomain.com
SMTP_FROM_NAME=Citadel Vault
SMTP_ENCRYPTION=tls                         # tls (port 587) or ssl (port 465)
ADMIN_EMAIL=admin@yourdomain.com            # Receives invite requests

# ─── External APIs (optional) ────────────────────────────
EXCHANGE_RATE_API_KEY=                       # https://app.exchangerate-api.com
ALPHA_VANTAGE_API_KEY=demo                  # Stock ticker data

# ─── Branding ────────────────────────────────────────────
APP_NAME=Citadel
APP_TAGLINE=Secure Personal Hub

# ─── Frontend (build-time only — compiled into JS by Vite) ──
VITE_APP_NAME=Citadel
VITE_APP_TAGLINE=Secure Personal Hub
VITE_API_BASE_URL=/src/api
