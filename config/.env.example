# ===========================================================================
# Citadel Vault — Environment Configuration
# ===========================================================================
# Copy this file to .env and update with your values.
# NEVER commit .env to version control — it contains secrets.
# ===========================================================================

# ─── Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=citadel_vault_db
DB_USER=citadel_db_admin
DB_PASS=example-db-password                  # REQUIRED. Change this. Use a strong unique password.

# ─── Encryption Secrets ──────────────────────────────────
# REQUIRED. App will refuse to start in production without these.
# Generate with: openssl rand -hex 32
DATA_SESSION_SECRET=replace-me-run-openssl-rand-hex-32   # CHANGE THIS. Encrypts vault data session tokens.

# ─── JWT ─────────────────────────────────────────────────
# REQUIRED. App will refuse to start in production without this.
# Generate with: openssl rand -hex 64
JWT_SECRET=replace-me-run-openssl-rand-hex-64            # CHANGE THIS. Signs all JWT auth tokens.
JWT_EXPIRY=28800                            # Token lifetime in seconds (default: 8 hours)

# ─── WebAuthn (Passkey Login) ────────────────────────────
# WARNING: Changing RP_ID or ORIGIN after users register passkeys
# will permanently invalidate those passkeys. Set once, don't change.
WEBAUTHN_RP_ID=localhost                    # Domain only, no protocol (e.g., yourdomain.com)
WEBAUTHN_RP_NAME=Citadel                    # Display name shown in passkey prompts
WEBAUTHN_ORIGIN=http://localhost:8080       # Full origin with protocol (e.g., https://yourdomain.com)

# ─── External APIs (Optional) ───────────────────────────
EXCHANGE_RATE_API_KEY=your-api-key-here      # From https://app.exchangerate-api.com — for daily currency rates
ALPHA_VANTAGE_API_KEY=demo                  # For stock ticker data (optional)

# ─── Encryption Tuning ─────────────────────────────────
# WARNING: Changing PBKDF2_ITERATIONS on a running system breaks all
# existing vault key derivations. Users would need to re-setup their vault.
# Only change BCRYPT_COST for NEW password hashes (existing ones auto-verify).
PBKDF2_ITERATIONS=100000                    # PBKDF2-SHA256 iterations for vault key derivation
BCRYPT_COST=12                              # bcrypt cost factor for password hashing (10-14 typical)

# ─── Session Expiry (seconds) ─────────────────────────
# Controls how long the vault stays unlocked per session type.
DATA_SESSION_EXPIRY_TIMED=3600              # "Timed" mode: auto-lock after this many seconds (default: 1 hour)
DATA_SESSION_EXPIRY_SESSION=86400           # "Browser Session" mode: max lifetime (default: 24 hours)
# "Until Logout" mode uses JWT_EXPIRY value automatically.

# ─── Account Lockout ───────────────────────────────────
# Progressive lockout on failed login AND vault unlock attempts.
# Tier 1: temporary cooldown. Tier 2: longer cooldown.
# Tier 3: full lock — forces password change (login) or vault key change (vault).
# Email notification sent at each tier.
LOCKOUT_TIER1_ATTEMPTS=3                    # Failures before tier 1 lockout
LOCKOUT_TIER1_DURATION=900                  # Tier 1 cooldown in seconds
LOCKOUT_TIER2_ATTEMPTS=6                    # Failures before tier 2 lockout
LOCKOUT_TIER2_DURATION=3600                 # Tier 2 cooldown in seconds
LOCKOUT_TIER3_ATTEMPTS=9                    # Failures before permanent lock + forced credential change

# ─── Rate Limiting ────────────────────────────────────
# Per-IP (hashed) limits on public unauthenticated endpoints.
# Format: max attempts / window in seconds. Blocks with HTTP 429.
RATE_LIMIT_LOGIN_IP=20                      # Login: max failures from one IP before blocking
RATE_LIMIT_LOGIN_IP_WINDOW=900              # Login: window in seconds (default: 15 min)
RATE_LIMIT_REGISTER=5                       # Register: max attempts per IP or email hash
RATE_LIMIT_REGISTER_WINDOW=3600             # Register: window in seconds (default: 1 hour)
RATE_LIMIT_FORGOT_PW=5                      # Forgot password: max attempts per IP
RATE_LIMIT_FORGOT_PW_WINDOW=3600            # Forgot password: window in seconds
RATE_LIMIT_INVITE_REQ=3                     # Invite request (public form): max per IP
RATE_LIMIT_INVITE_REQ_WINDOW=3600           # Invite request: window in seconds

# ─── Vault Key Policy ──────────────────────────────────
# Controls what vault keys users can create.
# Mode: 'numeric' (digits only), 'alphanumeric' (letters+digits), 'any' (all chars)
# Affects input type on frontend (numeric keyboard vs text) and backend validation.
VAULT_KEY_MIN_LENGTH=8                      # Minimum characters for new vault keys
VAULT_KEY_MODE=alphanumeric                 # numeric | alphanumeric | any

# ─── Password Policy ───────────────────────────────────
# Prevents reuse of recent passwords on all password change flows.
PASSWORD_HISTORY_COUNT=1                    # Block reuse of last N passwords (0 = disabled)

# ─── Registration ──────────────────────────────────────
# Controls who can create accounts.
SELF_REGISTRATION=false                     # true = anyone can register; false = invite-only
REQUIRE_EMAIL_VERIFICATION=false            # true = new self-registered users must verify email

# ─── SMTP Email ────────────────────────────────────────
# Used for: invite emails, lockout notifications, email verification,
# welcome emails for admin-created accounts, invite request forwarding.
SMTP_ENABLED=false                          # Master switch — false = no emails sent
SMTP_HOST=smtp.example.com                  # SMTP server hostname
SMTP_PORT=587                               # Port (587 = STARTTLS, 465 = SSL)
SMTP_USER=your-smtp-login                   # SMTP login username
SMTP_PASS=your-smtp-password                # SMTP login password / API key
SMTP_FROM=no-reply@yourdomain.com           # Sender email address. Change to your domain.
SMTP_FROM_NAME=Citadel Vault               # Sender display name
SMTP_ENCRYPTION=tls                         # tls (STARTTLS on 587) or ssl (on 465)

# ─── Application ────────────────────────────────────────
APP_ENV=development                         # 'development' = verbose errors; 'production' = errors hidden + fail-closed checks
APP_URL=http://localhost:8081               # Base URL for email links and invites (can differ from WEBAUTHN_ORIGIN)
BASE_CURRENCY=GBP                           # Default currency for portfolio aggregation
ALLOWED_ORIGINS=*                           # CORS allowed origins (* only safe in dev; set to domain in prod)
VITE_API_BASE_URL=/src/api                  # Frontend API path prefix

# ─── Encryption Mode ───────────────────────────────────
# System default for new users. Per-user override stored in DB.
# 'server' = encryption in PHP (current), 'client' = encryption in browser (future)
ENCRYPTION_MODE=server

# ─── Admin Contact ──────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com            # Receives invite requests from the registration page

# ─── Branding ─────────────────────────────────────────
APP_NAME=Citadel                            # App name shown in emails, page titles
APP_TAGLINE=Secure Personal Hub             # Shown on login/register pages
VITE_APP_NAME=Citadel                       # Frontend app name (compiled into JS)
VITE_APP_TAGLINE=Secure Personal Hub        # Frontend tagline (compiled into JS)
