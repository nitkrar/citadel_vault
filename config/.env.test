DB_HOST=localhost
DB_PORT=3306
DB_NAME=citadel_vault_test_db
DB_USER=nitinkum
DB_PASS=

APP_ENV=development

VAULT_KEY_MIN_LENGTH=3
VAULT_KEY_MODE=numeric

JWT_SECRET=test-jwt-secret-not-for-production-use-only-for-automated-tests-1234567890abcdef
AUDIT_HMAC_SECRET=test-audit-hmac-secret-not-for-production
SHARING_TOKEN_SECRET=test-sharing-token-secret-not-for-production

WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Citadel Test
WEBAUTHN_ORIGIN=http://localhost:8082

SELF_REGISTRATION=true
REQUIRE_EMAIL_VERIFICATION=false

ALLOWED_ORIGINS=*
SMTP_ENABLED=false

RATE_LIMIT_LOGIN_IP=1000
RATE_LIMIT_LOGIN_IP_WINDOW=60
RATE_LIMIT_REGISTER=1000
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_FORGOT_PW=1000
RATE_LIMIT_FORGOT_PW_WINDOW=60

LOCKOUT_TIER1_ATTEMPTS=3
LOCKOUT_TIER1_DURATION=900
LOCKOUT_TIER2_ATTEMPTS=6
LOCKOUT_TIER2_DURATION=3600
LOCKOUT_TIER3_ATTEMPTS=9
