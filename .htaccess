DirectoryIndex index.php

RewriteEngine On
RewriteBase /

# Pass Authorization header to PHP (required for nginx/FastCGI on shared hosting)
RewriteCond %{HTTP:Authorization} .+
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# API routes
RewriteRule ^src/api/(.+\.php)$ src/api/$1 [L,QSA]

# Block direct access to sensitive directories
RewriteRule ^config/ - [F,L]
RewriteRule ^database/ - [F,L]
RewriteRule ^scripts/ - [F,L]
RewriteRule ^static/ - [F,L]
RewriteRule ^src/core/ - [F,L]

# Serve version.json and registerSW.js from dist/ (before the block rule)
RewriteRule ^version\.json$ dist/version.json [L]
RewriteRule ^registerSW\.js$ dist/registerSW.js [L]

# Allow robots.txt through
RewriteRule ^robots\.txt$ - [L]

# Block sensitive file types (RewriteRule-based — avoids Require/mod_authz_core issues on shared hosting)
RewriteRule \.(env|sql|md|sh|py|lock|log|txt|json)$ - [F,L]

# Block dotfiles (except .htaccess)
RewriteRule /\. - [F,L]

# Don't rewrite existing files
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Serve static assets from dist/ (CSS, favicon)
RewriteRule ^(styles\.css|favicon\.svg)$ dist/$1 [L]

# Serve built JS/CSS assets from dist/assets/
RewriteRule ^assets/(.*)$ dist/assets/$1 [L]

# SPA fallback — serves built index.html via PHP
RewriteRule ^ index.php [L]

# Security headers (only if mod_headers is available)
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    Header always set X-Robots-Tag "noindex, nofollow"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; form-action 'self'; base-uri 'self'"
</IfModule>
